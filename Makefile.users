# Makefile to create executables for user1.c and user2.c

CC = gcc
CFLAGS = -Wall -g
LDFLAGS = -L. -lksocket

# Default target builds both users
all: user1 user2

# Build user1
user1: user1.c ksocket.h
	$(CC) $(CFLAGS) user1.c -o user1 $(LDFLAGS)

# Build user2
user2: user2.c ksocket.h
	$(CC) $(CFLAGS) user2.c -o user2 $(LDFLAGS)

# Clean rule specific to the users and test files
clean:
	rm -f user1 user2 input.txt output.txt